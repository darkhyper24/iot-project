<?xml version="1.0" encoding="UTF-8"?>
<!-- Copy over config.xml after running scripts/gen_broker_keystore.sh (needs broker.jks in config/certs). -->
<hivemq>

    <listeners>
        <tcp-listener>
            <port>1883</port>
            <bind-address>0.0.0.0</bind-address>
            <name>mqtt-plain</name>
        </tcp-listener>

        <tls-tcp-listener>
            <port>8883</port>
            <bind-address>0.0.0.0</bind-address>
            <name>mqtt-tls</name>
            <tls>
                <keystore>
                    <path>/opt/hivemq/certs/broker.jks</path>
                    <password>changeit</password>
                    <private-key-password>changeit</private-key-password>
                </keystore>
                <client-authentication-mode>NONE</client-authentication-mode>
            </tls>
        </tls-tcp-listener>
    </listeners>

</hivemq>
