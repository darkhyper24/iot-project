<?xml version="1.0" encoding="UTF-8"?>
<!--
  Rendered by scripts/gen_credentials.py from config.yaml + the master MQTT secret.
  This template file is a placeholder — regenerate before first boot. DO NOT COMMIT
  real hashes to version control in a real deployment; for this course project the
  derivation is HMAC-SHA256(master, username) printed in hex.
-->
<file-rbac xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <users>
        <!-- Admin + integration + benchmark users -->
        <user>
            <name>admin</name>
            <password>admin-secret</password>
            <roles><id>admin-role</id></roles>
        </user>
        <user>
            <name>tb-integration</name>
            <password>tb-integration-secret</password>
            <roles><id>integration-role</id></roles>
        </user>
        <user>
            <name>rtt-bench</name>
            <password>rtt-bench-secret</password>
            <roles><id>bench-role</id></roles>
        </user>

        <!-- Per-floor gateways (10). Per-room device users (200) are appended by gen_credentials.py. -->
        <user><name>gw-f01</name><password>gw-f01-secret</password><roles><id>gw-f01-role</id></roles></user>
        <user><name>gw-f02</name><password>gw-f02-secret</password><roles><id>gw-f02-role</id></roles></user>
        <user><name>gw-f03</name><password>gw-f03-secret</password><roles><id>gw-f03-role</id></roles></user>
