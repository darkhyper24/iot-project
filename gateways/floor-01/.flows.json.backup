      ]
    ]
  },
  {
    "id": "5518e8a7c16c4f70",
    "type": "function",
    "name": "CoAP Observe f01 (rooms 011-020)",
    "func": "// CoAP Observe \u2192 ThingsBoard \u2014 Floor 01 (rooms 011-020)\n// Triggered once on startup; node.send() fires for every CoAP notification.\n// 'coap' is injected via the node's libs declaration (functionExternalModules: true).\n\nvar rooms = [\n    {pathname:'/f01/r111/telemetry', device:'b01-f01-r011'},\n    {pathname:'/f01/r112/telemetry', device:'b01-f01-r012'},\n    {pathname:'/f01/r113/telemetry', device:'b01-f01-r013'},\n    {pathname:'/f01/r114/telemetry', device:'b01-f01-r014'},\n    {pathname:'/f01/r115/telemetry', device:'b01-f01-r015'},\n    {pathname:'/f01/r116/telemetry', device:'b01-f01-r016'},\n    {pathname:'/f01/r117/telemetry', device:'b01-f01-r017'},\n    {pathname:'/f01/r118/telemetry', device:'b01-f01-r018'},\n    {pathname:'/f01/r119/telemetry', device:'b01-f01-r019'},\n    {pathname:'/f01/r120/telemetry', device:'b01-f01-r020'}\n];\n\nrooms.forEach(function(room) {\n    var req = coap.request({\n        hostname: 'simulator',\n        port: 5683,\n        pathname: room.pathname,\n        method: 'GET',\n        observe: true\n    });\n    req.on('response', function(res) {\n        res.on('data', function(data) {\n            try {\n                var d = JSON.parse(data.toString());\n                var ts = d.timestamp ? d.timestamp * 1000 : Date.now();\n                node.send({\n                    topic: 'v1/gateway/telemetry',\n                    payload: JSON.stringify({\n                        [room.device]: [{\n                            ts: ts,\n                            values: {\n                                temperature:     d.temperature,\n                                humidity:        d.humidity,\n                                occupancy:       d.occupancy,\n                                light_level:     d.light_level,\n                                hvac_mode:       d.hvac_mode,\n                                lighting_dimmer: d.lighting_dimmer,\n                                target_temp:     d.target_temp,\n                                fault:           d.fault\n                            }\n                        }]\n                    })\n                });\n            } catch(e) {}\n        });\n    });\n    req.on('error', function(e) {\n        node.error('CoAP ' + room.device + ': ' + e.message);\n    });\n    req.end();\n});\nreturn null;",
    "libs": [
      {
        "var": "coap",
        "module": "coap"
      }
    ],
    "outputs": 1,
    "x": 380,
    "y": 200,
    "z": "6653fb14664c4f8f",
    "wires": [
      [
        "4b6dc2fc3c524401"
      ]
    ]
