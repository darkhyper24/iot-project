# Copy to `.env` in the project root (Compose reads it for variable substitution and optional env_file).
# Never commit real secrets.

# --- Database (simulator) ---
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=iot_user
# DB_PASSWORD=iot_password
# DB_NAME=iot_campus

# --- Simulation tuning ---
# SIM_TICK_INTERVAL=5
# SIM_MAX_JITTER=5
# SIM_DB_SYNC_INTERVAL=30
# SIM_TIME_ACCELERATION=1.0
# SIM_FLOORS=10
# SIM_ROOMS_PER_FLOOR=20

# --- MQTT (simulator → HiveMQ) ---
MQTT_BROKER_HOST=hivemq
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
MQTT_TLS_CAFILE=/app/config/certs/ca.crt
# MQTT_TLS_CERTFILE=/app/config/certs/client.crt
# MQTT_TLS_KEYFILE=/app/config/certs/client.key
MQTT_TLS_CHECK_HOSTNAME=false
# Shared fallback if mqtt_nodes.json is absent (not used when per-node file is present):
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CREDENTIALS_FILE=/app/config/secrets/mqtt_nodes.json

# --- Phase 2 / CoAP ---
COAP_PSK_FILE=/app/config/secrets/coap_psk.json
# COAP_BIND_HOST=0.0.0.0
# COAP_BIND_PORT=5683
COAP_DTLS_ENABLED=true
# COAP_DTLS_BIND_HOST=0.0.0.0
# COAP_DTLS_BIND_PORT=5684
# COAP_PSK_IDENTITY=
# COAP_PSK_HEX=

# --- Thermal / faults / heartbeat (optional overrides) ---
# SIM_THERMAL_ALPHA=0.01
# SIM_THERMAL_BETA=0.2
# SIM_DEFAULT_TEMP=22.0
# SIM_OUTSIDE_TEMP=35.0
# SIM_OCCUPANCY_HEAT=0.05
# SIM_LIGHT_THRESHOLD=300
# SIM_FAULT_PROBABILITY=0.01
# SIM_HEARTBEAT_INTERVAL=10
# SIM_HEARTBEAT_TIMEOUT=60
# PHASE2_MQTT_ROOMS_PER_FLOOR=10
# PHASE2_MQTT_STAGGER_S=0.05

# --- HiveMQ (service env; optional) ---
# HIVEMQ_LOG_LEVEL=INFO
